    {
      "type": "text", "id": "s1_desc1", "x": 280, "y": 318, "width": 280, "height": 40,
      "text": "Screen S&P 500 → research →\nsave tomorrow's pending signals",
      "originalText": "Screen S&P 500 → research →\nsave tomorrow's pending signals",
      "fontSize": 12, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top",
      "strokeColor": "#64748b", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
