# =============================================================================
# .env.example — Copy to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application -------------------------------------------------------------
ENV=development                         # development | staging | production
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true

# --- Model provider ----------------------------------------------------------
# bedrock   : LLM calls go through AWS Bedrock (needs AWS creds below)
# anthropic : LLM calls go directly to Anthropic API (no AWS required)
MODEL_PROVIDER=bedrock
ANTHROPIC_API_KEY=
ANTHROPIC_MAX_TOKENS=8192

# --- AWS / Amazon Bedrock ----------------------------------------------------
# Required only when MODEL_PROVIDER=bedrock
AWS_REGION=us-east-1
# Leave blank to use IAM role / instance profile / AWS SSO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251001-v1:0

# --- Alpaca Markets (Broker) -------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Paper trading by default. Switch to https://api.alpaca.markets for live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex                    # iex (free) | sip (paid full NBBO)

# --- Market Data -------------------------------------------------------------
POLYGON_API_KEY=your_polygon_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
ALPHA_VANTAGE_RATE_LIMIT_PER_MINUTE=5  # Free tier: 5 req/min
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Risk Limits -------------------------------------------------------------
RISK_MAX_POSITION_PCT=0.02             # 2% per position
RISK_MAX_SIMULTANEOUS_POSITIONS=8
RISK_MAX_DRAWDOWN_PCT=0.15             # Halt at 15% portfolio MDD
RISK_DAILY_MAX_LOSS_PCT=0.05           # Halt at 5% daily loss
RISK_ATR_STOP_MULTIPLIER=2.0           # Stop = entry ± (2 × ATR)
RISK_CONSECUTIVE_LOSS_HALT=3           # Halt after 3 consecutive losses

# --- Quant Parameters --------------------------------------------------------
QUANT_MOMENTUM_LOOKBACK_DAYS=252       # 12-month lookback
QUANT_MOMENTUM_SKIP_DAYS=21            # Skip most-recent 1 month (reversal avoidance)
QUANT_MEAN_REVERSION_ZSCORE_WINDOW=20
QUANT_ADX_TRENDING_THRESHOLD=25.0
QUANT_UNIVERSE_SIZE=50
QUANT_MIN_AVG_DAILY_VOLUME=1000000     # Minimum $1M ADV for universe inclusion

# --- Scheduler ---------------------------------------------------------------
SCHEDULER_INTRADAY_HOUR=13
SCHEDULER_INTRADAY_MINUTE=30
SCHEDULER_EOD_HOUR=16
SCHEDULER_EOD_MINUTE=0
SCHEDULER_TIMEZONE=America/New_York

# --- State / Cache -----------------------------------------------------------
STATE_FILE_PATH=.state/portfolio_state.json
CACHE_DIR=.cache
